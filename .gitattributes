# Set default behavior to automatically normalize line endings
* text=auto

# C# source files - use CRLF (Windows) line endings
*.cs text eol=crlf

# Project files
*.csproj text eol=crlf
*.sln text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Config files
*.config text eol=crlf
*.json text eol=lf
# Golden wire traces are byte-compared LF-exact by the test harness.
*.jsonl text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# Markdown and documentation
*.md text eol=lf

# Prevent binary files from being modified
*.dll binary
*.exe binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
